  create view "ecommerce_db"."public"."enriched_reviews__dbt_tmp"
    
    
  as (
    -- ═════════════════════════════════════════
-- Staging: Enriched Reviews with Sentiment
-- (100% FREE)
-- ═════════════════════════════════════════

SELECT
    review_id,
    product_id,
    customer_id,
    rating,
    review_text,
    sentiment_label,
    sentiment_score,
    psychological_insights,
    confidence_score,
    enriched_at,
    
    -- Clean sentiment label
    CASE
        WHEN sentiment_label = 'POSITIVE' THEN 'positive'
        WHEN sentiment_label = 'NEGATIVE' THEN 'negative'
        ELSE 'neutral'
    END AS sentiment_clean,
    
    -- Extract confidence
    COALESCE(
        (psychological_insights::json->>'confidence')::DECIMAL,
        0.0
    ) AS confidence_extracted

FROM "ecommerce_db"."public"."enriched_reviews"
  );
